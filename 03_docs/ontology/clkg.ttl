clkg:hasEmotionType a owl:DatatypeProperty ;
    rdfs:label "情绪类别"@zh ;
    rdfs:domain clkg:Document ;
    rdfs:range xsd:string .

clkg:hasEnvironment a owl:DatatypeProperty ;
    rdfs:domain clkg:Place ;
    rdfs:range xsd:string .

clkg:hasEra a owl:DatatypeProperty ;
    rdfs:label "年代"@zh ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( clkg:Document clkg:Event clkg:Place ) ] ;
    rdfs:range xsd:string .

clkg:hasEventType a owl:DatatypeProperty ;
    rdfs:label "事件类型"@zh ;
