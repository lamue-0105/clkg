    rdfs:label "遗产类别"@zh ;
    rdfs:domain clkg:Place ;
    rdfs:range xsd:string .

clkg:hasChapter a owl:DatatypeProperty ;
    rdfs:label "章"@zh ;
    rdfs:domain clkg:Event ;
    rdfs:range xsd:string .

clkg:hasCollectionNumber a owl:DatatypeProperty ;
    rdfs:label "馆藏号"@zh ;
    rdfs:domain clkg:Document ;
    rdfs:range xsd:string .

clkg:hasConcept a owl:DatatypeProperty ;
    rdfs:label "概念"@zh ;
    rdfs:domain clkg:Event ;
