clkg:hasCurrency a owl:DatatypeProperty ;
    rdfs:label "币种(侨批)"@zh ;
    rdfs:domain clkg:Document ;
    rdfs:range xsd:string .

clkg:hasDescription a owl:DatatypeProperty ;
    rdfs:label "描述"@zh ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( clkg:CulturalLandscapeUnit clkg:Event clkg:Place ) ] ;
    rdfs:range xsd:string .

clkg:hasDistrict a owl:DatatypeProperty ;
    rdfs:domain clkg:Place ;
    rdfs:range xsd:string .

clkg:hasEmotion a owl:DatatypeProperty ;
    rdfs:label "情感极性"@zh ;
    rdfs:domain clkg:Document ;
