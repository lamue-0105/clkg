@prefix clkg: <https://w3id.org/clkg/ontology#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix geo:  <http://www.opengis.net/ont/geosparql#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix crm:  <http://www.cidoc-crm.org/cidoc-crm/> .


<https://w3id.org/clkg/ontology> a owl:Ontology ;
    rdfs:label "CL-Onto · 文化景观知识图谱本体"@zh ;
    owl:versionInfo "0.1" ;
    rdfs:comment "CIDOC-CRM 精简对齐 + PROV-O 溯源 + 4D-fluent 时态 + RDF-star。由 ingest.ontology 从活库自动生成。"@zh .

# ── 类（Classes）──
clkg:Place a owl:Class ;
    rdfs:label "地点"@zh, "Place"@en ;
    skos:closeMatch crm:E53_Place ;
    rdfs:comment "entity_type=pl"@zh .

clkg:CulturalLandscapeUnit a owl:Class ;
    rdfs:label "文化景观单元"@zh, "CulturalLandscapeUnit"@en ;
    skos:closeMatch crm:E27_Site ;
    rdfs:comment "entity_type=clu"@zh .

clkg:Actor a owl:Class ;
    rdfs:label "行动者"@zh, "Actor"@en ;
    skos:closeMatch crm:E39_Actor ;
    rdfs:comment "entity_type=ac"@zh .

clkg:Document a owl:Class ;
    rdfs:label "文档"@zh, "Document"@en ;
    skos:closeMatch crm:E31_Document ;
    rdfs:comment "entity_type=doc"@zh .

clkg:Event a owl:Class ;
    rdfs:label "事件"@zh, "Event"@en ;
    skos:closeMatch crm:E5_Event ;
    rdfs:comment "entity_type=ev"@zh .

clkg:DigitalImage a owl:Class ;
    rdfs:label "图像"@zh, "DigitalImage"@en ;
    skos:closeMatch crm:E36_Visual_Item ;
    rdfs:comment "entity_type=img"@zh .

clkg:Evidence a owl:Class ; rdfs:subClassOf prov:Entity ;
    rdfs:label "证据/溯源"@zh, "Evidence"@en .

# ── 对象属性 / 关系边（9）──
clkg:carriedOutBy a owl:ObjectProperty ;
    rdfs:domain clkg:Event ;
    rdfs:range clkg:Actor ;
    skos:closeMatch crm:P14_carried_out_by ;
    rdfs:comment "272 statements"@en .

clkg:containsPlace a owl:ObjectProperty ;
    rdfs:domain clkg:CulturalLandscapeUnit ;
    rdfs:range clkg:Place ;
    skos:closeMatch crm:P89_falls_within ;
    rdfs:comment "682 statements"@en .

clkg:hasDestinationPlace a owl:ObjectProperty ;
    rdfs:label "寄达地(侨批)"@zh ;
    rdfs:domain clkg:Document ;
    rdfs:range clkg:Place ;
    rdfs:comment "12391 statements"@en .

clkg:hasOriginPlace a owl:ObjectProperty ;
    rdfs:label "寄出地(侨批)"@zh ;
    rdfs:domain clkg:Document ;
    rdfs:range clkg:Place ;
    rdfs:comment "9805 statements"@en .

clkg:hasRecipient a owl:ObjectProperty ;
    rdfs:label "收件人(侨批)"@zh ;
    rdfs:domain clkg:Document ;
    rdfs:range clkg:Actor ;
    rdfs:comment "13446 statements"@en .

clkg:hasSender a owl:ObjectProperty ;
    rdfs:label "寄件人(侨批)"@zh ;
    rdfs:domain clkg:Document ;
    rdfs:range clkg:Actor ;
    rdfs:comment "13402 statements"@en .

clkg:mentionsGroup a owl:ObjectProperty ;
    rdfs:domain clkg:Event ;
    rdfs:range clkg:Actor ;
    rdfs:comment "190 statements"@en .

clkg:mentionsPlaceEntity a owl:ObjectProperty ;
    rdfs:domain clkg:Document ;
    rdfs:range clkg:Place ;
    rdfs:comment "4100 statements"@en .

clkg:tookPlaceIn a owl:ObjectProperty ;
    rdfs:domain clkg:Event ;
    rdfs:range clkg:Place ;
    skos:closeMatch crm:P7_took_place_at ;
    rdfs:comment "231 statements"@en .

# ── 空间属性（1）──
clkg:locatedAt a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( clkg:CulturalLandscapeUnit clkg:DigitalImage clkg:Document clkg:Place ) ] ;
    rdfs:range geo:Geometry ;
    skos:closeMatch crm:P168_place_is_defined_by ;
    rdfs:comment "object_geometry, SRID 4326 (WGS84)"@en .

# ── 数据属性 / 字面值（76）──
clkg:capturedAt a owl:DatatypeProperty ;
    rdfs:label "拍摄时间"@zh ;
    rdfs:domain clkg:DigitalImage ;
    rdfs:range xsd:string .

clkg:hasAbstract a owl:DatatypeProperty ;
    rdfs:label "内容摘要"@zh ;
    rdfs:domain clkg:Document ;
    rdfs:range xsd:string .

clkg:hasAddress a owl:DatatypeProperty ;
    rdfs:label "地址"@zh ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( clkg:Event clkg:Place ) ] ;
    rdfs:range xsd:string .

clkg:hasAdminCode a owl:DatatypeProperty ;
    rdfs:domain clkg:Place ;
    rdfs:range xsd:string .

