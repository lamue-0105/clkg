  CulturalLandscapeUnit -> Geometry [label="locatedAt",style=dashed,color="#3a8a55"];
  Document -> Geometry [label="locatedAt",style=dashed,color="#3a8a55"];
  DigitalImage -> Geometry [label="locatedAt",style=dashed,color="#3a8a55"];
  Place -> Geometry [label="locatedAt",style=dashed,color="#3a8a55"];
}