# Copy this file to .env and fill in your values.
# .env is loaded automatically by ingest/config.py.

# ---- PostgreSQL ------------------------------------------------------------
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
# Database name pattern: {region}_cl_kg  (e.g. mustang_cl_kg)
# Override the suffix here if your naming differs.
PG_DB_SUFFIX=_cl_kg

# ---- NAS / data root -------------------------------------------------------
# Root of the heritage data NAS mount on this machine.
# Per-project layout expected underneath:
#   {NAS_ROOT}/{project}/tabular/*.csv,*.xlsx
#   {NAS_ROOT}/{project}/photos/{natural_key}/*.jpg,*.png
#   {NAS_ROOT}/{project}/gis/*.shp,*.geojson  (future)
NAS_ROOT=/Volumes/clkg_data

# ---- Qwen NER (optional) ---------------------------------------------------
# Leave empty to disable LLM-based NER. The pipeline runs fine without it —
# you just get fewer 'mentions' statements.
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---- Pipeline behaviour ----------------------------------------------------
# Set to 1 to enable NER even if you have to pay for API calls today.
ENABLE_NER=0
